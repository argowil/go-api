# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# --- Server ---
PORT=8080

# --- MySQL (running locally on Mac) ---
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=argowil
DB_USER=argowil_user
DB_PASSWORD=changeme

# --- JWT ---
# Use a long random string — openssl rand -hex 32
JWT_SECRET=replace_this_with_a_secure_random_string
JWT_ACCESS_TTL_MINUTES=15
JWT_REFRESH_TTL_DAYS=30

# --- Server ---
# Set to your local IP so uploaded images are reachable from phones on the same network
SERVER_BASE_URL=http://10.10.33.98:8080

# --- Shiftbase (optional) ---
# Leave SHIFTBASE_API_KEY empty to disable Shiftbase and use local data.
# Get your key from: Shiftbase → Settings → App center → Public API
SHIFTBASE_API_KEY=
SHIFTBASE_BASE_URL=https://api.shiftbase.com
# Department ID that new employees are assigned to by default.
# Find it in Shiftbase → Settings → Departments → copy the numeric ID from the URL.
SHIFTBASE_DEFAULT_DEPARTMENT_ID=
